# TX-5DR Server Configuration
# Edit this file to customize your deployment.
# After editing, restart the service: tx5dr restart

NODE_ENV=production

# Backend API port (internal, proxied by nginx)
PORT=4000

# rtc-data-audio WebRTC DataChannel media UDP port. This is intentionally a
# single fixed port to simplify LAN tunneling and external port forwarding.
RTC_DATA_AUDIO_UDP_PORT=50110
RTC_DATA_AUDIO_ICE_UDP_MUX=1

# External rtc-data-audio public host/port is managed from System Settings.

# HTTP port for web UI (nginx listen port)
TX5DR_HTTP_PORT=8076

# Data directories
TX5DR_CONFIG_DIR=/var/lib/tx5dr/config
TX5DR_DATA_DIR=/var/lib/tx5dr
# User plugins live under ${TX5DR_DATA_DIR}/plugins
TX5DR_LOGS_DIR=/var/lib/tx5dr/logs
TX5DR_CACHE_DIR=/var/lib/tx5dr/cache
# Download source policy for install-online.sh and `tx5dr update`
# auto   = use OSS only when geolocation detects mainland China
# github = always use GitHub release assets
# oss    = always prefer OSS mirror
TX5DR_DOWNLOAD_SOURCE=auto

# Optional: force server-only CPU profiling for performance diagnostics.
# Do not set NODE_OPTIONS here. These variables are consumed only by the
# shared server launcher, so Electron main, nginx and other child
# processes will not inherit --cpu-prof.
# Files are written only after the server exits cleanly.
# TX5DR_SERVER_CPU_PROFILE=1
# TX5DR_SERVER_CPU_PROFILE_DIR=/var/lib/tx5dr/logs/diagnostics/cpu
# TX5DR_SERVER_CPU_PROFILE_NAME=tx5dr-server-manual.cpuprofile
# TX5DR_SERVER_CPU_PROFILE_INTERVAL=1000
