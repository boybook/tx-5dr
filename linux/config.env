# TX-5DR Server Configuration
# Edit this file to customize your deployment.
# After editing, restart the service: tx5dr restart

NODE_ENV=production

# Backend API port (internal, proxied by nginx)
PORT=4000

# LiveKit ports. If browsers will connect from other machines,
# also expose these ports on your firewall / public mapping.
LIVEKIT_SIGNAL_PORT=7880
LIVEKIT_TCP_PORT=7881
LIVEKIT_UDP_PORT_START=50000
LIVEKIT_UDP_PORT_END=50100
LIVEKIT_CREDENTIALS_FILE=/etc/tx5dr/livekit-credentials.env

# Public browser LiveKit URL override is stored in config.json
# and should be managed from the System Settings page.

# HTTP port for web UI (nginx listen port)
TX5DR_HTTP_PORT=8076

# Data directories
TX5DR_CONFIG_DIR=/var/lib/tx5dr/config
TX5DR_DATA_DIR=/var/lib/tx5dr
TX5DR_LOGS_DIR=/var/lib/tx5dr/logs
TX5DR_CACHE_DIR=/var/lib/tx5dr/cache
LIVEKIT_CONFIG_FILE=/etc/tx5dr/livekit.yaml
LIVEKIT_URL=ws://127.0.0.1:7880

# Download source policy for install-online.sh and `tx5dr update`
# auto   = use OSS only when geolocation detects mainland China
# github = always use GitHub release assets
# oss    = always prefer OSS mirror
TX5DR_DOWNLOAD_SOURCE=auto
