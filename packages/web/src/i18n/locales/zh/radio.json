    "tuner_switch": {
      "label": "自动天调",
      "description": "控制电台内置天线自动调谐器的开关状态。开启后，电台会自动匹配天线阻抗以降低驻波比（SWR），改善发射效率。建议在更换频段或天线后重新调谐。"
    },
    "tuner_tune": {
      "label": "手动调谐",
      "description": "立即触发一次天调匹配过程。需先开启自动天调开关。调谐期间电台会短暂发射低功率载波，请确保已连接天线再执行。"
    },
    "rf_power": {
      "label": "发射功率",
      "description": "控制电台的发射功率，范围 0–100%（对应电台额定最大功率）。数字模式通常建议适当降低功率，避免长时间全功率发射导致功放过热；语音通联可根据信道条件灵活调整。"
    },
    "af_gain": {
      "label": "AF 增益",
      "description": "调节电台本机扬声器或耳机接口的音频输出音量。仅影响电台硬件侧的音量，不影响软件监听功能的音量设置。"
    },
    "sql": {
      "label": "静噪",
      "description": "设置接收静噪门限。调高后，弱信号将被抑制，仅较强的信号才能开启音频输出。数字模式解码通常建议关闭静噪（设为 0）；语音通联时可适当调高以过滤背景噪声。"
    },
    "mic_gain": {
      "label": "MIC 增益",
      "description": "调节麦克风输入增益，控制发射音频的前置放大量。过高会导致音频过载失真，过低则信号弱、对方接收困难。语音通联时建议调至音频指示刚好进入黄区；数字模式通常不需要调整。"
    },
    "nb": {
      "label": "噪声消隐",
      "description": "噪声消隐器（NB），专门抑制脉冲型干扰，例如汽车点火噪声、工业电气干扰等。0 表示关闭，数值越大消隐强度越高。对持续性背景噪声效果有限，建议仅在有明显脉冲干扰时启用。"
    },
    "nr": {
      "label": "数字降噪",
      "description": "数字信号处理降噪（NR），通过 DSP 算法降低背景白噪声，提升弱信号可读性。0 表示关闭；进行 FT8 等数字模式解码时建议设为 0，避免 DSP 处理影响解码准确性。"
    }
  }
