{
  "$schema": "https://turborepo.org/schema.json",
  "globalPassThroughEnv": [
    "GLIBC_TUNABLES",
    "RIGCTLD_ENABLED",
    "RIGCTLD_BIND",
    "RIGCTLD_PORT",
    "RTC_DATA_AUDIO_UDP_PORT",
    "RTC_DATA_AUDIO_ICE_UDP_MUX"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": [
        "^build"
      ]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "outputs": []
    }
  },
  "globalDependencies": [
    "packages/shared-config/**"
  ]
}
