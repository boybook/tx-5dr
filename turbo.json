{
  "$schema": "https://turborepo.org/schema.json",
  "globalPassThroughEnv": [
    "LIVEKIT_URL",
    "LIVEKIT_DISABLED",
    "LIVEKIT_CREDENTIALS_FILE",
    "LIVEKIT_CONFIG_FILE",
    "LIVEKIT_CONFIG_PATH",
    "LIVEKIT_SIGNAL_PORT",
    "LIVEKIT_TCP_PORT",
    "LIVEKIT_UDP_PORT_RANGE",
    "LIVEKIT_API_KEY",
    "LIVEKIT_API_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "outputs": []
    }
  },
  "globalDependencies": ["packages/shared-config/**"]
} 
